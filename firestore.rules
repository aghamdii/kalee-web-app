rules_version = '2';

  service cloud.firestore {
    match /databases/{database}/documents {
      // Basic functions for reuse
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }

      // Users collection
      match /users/{userId} {
        allow read, write: if isOwner(userId);
      }

      // Profiles collection
      match /profiles/{userId} {
        allow read, write: if isOwner(userId);
      }

      // Meals collection
      match /meals/{mealId} {
        allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      }

      // Daily logs collection
      match /dailyLogs/{userId}/logs/{logId} {
        allow read, write: if isOwner(userId);
      }

      match /dailyLogs/{logId} {
        allow read, write: if isSignedIn() && logId.split('_')[0] == request.auth.uid;
      }

      // Favorite meals collection
      match /favoriteMeals/{favoriteId} {
        allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      }

      // Weights collection
      match /weights/{weightId} {
        allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      }

      // Water entries collection
      match /waterEntries/{entryId} {
        allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      }

      // Monthly stats collection
      match /monthlyStats/{statsId} {
        allow read, write: if isSignedIn() && statsId.split('_')[0] == request.auth.uid;
      }

      // ===== NEW COLLECTIONS FOR PRODUCT SCAN FEATURE =====

      // Carts collection
      match /carts/{cartId} {
        allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      }

      // Products collection
      match /products/{productId} {
        allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      }

      // Pantry products collection
      match /pantry_products/{productId} {
        allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      }

      // Feedback collection
      match /feedback/{feedbackId} {
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow read, update, delete: if false;
      }

      // User insights collection (onboarding research/marketing data)
      match /userInsights/{userId} {
        allow create, update: if isOwner(userId);
        allow read, delete: if false;
      }

      // Admin sync progress - readable by admin emails for real-time progress
      match /adminSyncProgress/{syncId} {
        allow read: if isSignedIn()
          && request.auth.token.email in ['alghamdii.ahmad@gmail.com', 'ahmadgh187@gmail.com'];
        allow write: if false;
      }
    }
  }
